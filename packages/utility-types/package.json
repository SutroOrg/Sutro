{
  "name": "@sutro-dev/utility-types",
  "version": "0.1.0",
  "description": "Small, battle-tested TypeScript utility types and helpers extracted from Sutro.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SutroOrg/utility-types.git"
  },
  "bugs": {
    "url": "https://github.com/SutroOrg/utility-types/issues"
  },
  "homepage": "https://github.com/SutroOrg/utility-types#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p ./tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "generate-password": "^1.7.1",
    "ulid": "^3.0.2",
    "uuid": "^13.0.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "zod": ">=3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt"
    ]
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/generate-password": "^1.5.3",
    "@types/node": "^22.18.0",
    "@types/react": "^19.2.14",
    "@types/uuid": "^10.0.0",
    "react": "^19.0.0",
    "typescript": "5.9.2",
    "vitest": "3.2.4",
    "zod": "3.25.76"
  }
}
